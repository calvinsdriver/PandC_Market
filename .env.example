# Optional: NewsAPI (https://newsapi.org/) - free tier ~100 requests/day
# Enables richer news search for P&C, Guidewire, and AI-in-insurance.
# NEWS_API_KEY=

# Optional: Run once immediately on startup (default: false)
# RUN_ONCE=

# Optional: Disable SSL verify for requests (dev only; not for production)
# USE_INSECURE_SSL=0

# LLM deep summaries via xAI (dashboard shows one summary per news category)
# XAI_API_KEY=
# XAI_MODEL=grok-3-mini-fast
